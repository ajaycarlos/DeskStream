# ====================================================================
.idea/
*.iml
*.ipr
*.iws
.idea/workspace.xml
.idea/tasks.xml
.idea/assetWizardSettings.xml
.idea/modules.xml
.idea/caches/
.idea/libraries/

# Cursor / VS Code / Sublime
.vscode/
.history/
*.sublime-project
*.sublime-workspace

# ====================================================================
